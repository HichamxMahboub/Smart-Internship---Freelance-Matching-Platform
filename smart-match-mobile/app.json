{
  "expo": {
    "name": "Interlance",
    "slug": "smart-match-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#f6f8fb"
    },
    "ios": { "supportsTablet": true },
    "android": { "adaptiveIcon": { "foregroundImage": "./assets/adaptive-icon.png", "backgroundColor": "#f6f8fb" }, "edgeToEdgeEnabled": true },
    "web": { "favicon": "./assets/favicon.png" },
    "plugins": [
      "expo-notifications",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Interlance to access your photos for profile and company images.",
          "cameraPermission": "Allow Interlance to use the camera for profile photos."
        }
      ],
      "expo-document-picker"
    ]
  }
}
