# Expo mobile environment notes.
# Configure actual values in src/config/env.ts.
API_BASE_URL=http://localhost:8080/api
# Android emulator backend URL: http://10.0.2.2:8080/api
# Physical phone backend URL: http://<computer-lan-ip>:8080/api
FIREBASE_API_KEY=replace-me
FIREBASE_AUTH_DOMAIN=replace-me.firebaseapp.com
FIREBASE_PROJECT_ID=replace-me
FIREBASE_STORAGE_BUCKET=replace-me.appspot.com
FIREBASE_MESSAGING_SENDER_ID=replace-me
FIREBASE_APP_ID=replace-me
