# Expo mobile public runtime config.
# Firebase client values are public app config, not Firebase Admin private keys.
EXPO_PUBLIC_API_BASE_URL=http://localhost:8080/api
EXPO_PUBLIC_WS_URL=ws://localhost:8080/ws
# Android emulator backend URL: http://10.0.2.2:8080/api and ws://10.0.2.2:8080/ws
# Physical phone backend URL: http://<computer-lan-ip>:8080/api and ws://<computer-lan-ip>:8080/ws
EXPO_PUBLIC_FIREBASE_API_KEY=replace-me
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=replace-me.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=replace-me
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=replace-me.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=replace-me
EXPO_PUBLIC_FIREBASE_APP_ID=replace-me
