# Interlance local / Docker Compose example
SPRING_DATA_MONGODB_URI=mongodb://mongodb:27017/smart_match
MONGODB_URI=mongodb://mongodb:27017/smart_match

FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_SERVICE_ACCOUNT_PATH=/run/secrets/firebase-service-account.json

APP_PAYMENT_WEBHOOK_SECRET=change-me
APP_SEED_ENABLED=true
APP_CV_UPLOAD_DIR=/uploads/cv

OPENROUTER_API_KEY=replace-with-demo-key
OPENROUTER_MODEL=deepseek/deepseek-chat-v3-0324:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

CLOUDINARY_CLOUD_NAME=replace-with-cloud-name
CLOUDINARY_API_KEY=replace-with-api-key
CLOUDINARY_API_SECRET=replace-with-api-secret
CLOUDINARY_IMAGE_FOLDER=interlance/images
CLOUDINARY_RESUME_FOLDER=interlance/resumes

MONGO_EXPRESS_USERNAME=admin
MONGO_EXPRESS_PASSWORD=change-me
