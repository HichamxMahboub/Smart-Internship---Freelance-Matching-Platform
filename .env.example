# Root Docker Compose environment example. Do not commit real secrets.
SPRING_DATA_MONGODB_URI=mongodb://mongodb:27017/smart_match
MONGODB_URI=mongodb://mongodb:27017/smart_match
FIREBASE_SERVICE_ACCOUNT_JSON=
# Docker Compose: copy your Firebase key to smart-match-backend/firebase-service-account.json
FIREBASE_SERVICE_ACCOUNT_PATH=/run/secrets/firebase-service-account.json
# Local demo secret. Replace in shared demos and never use the default in production.
APP_PAYMENT_WEBHOOK_SECRET=change-me
APP_SEED_ENABLED=true
APP_CV_UPLOAD_DIR=/uploads/cv
APP_MAX_FILE_SIZE=5MB
APP_MAX_REQUEST_SIZE=5MB

# Mongo Express local-only basic auth. Change before exposing port 8081.
MONGO_EXPRESS_USERNAME=smartmatch-dev
MONGO_EXPRESS_PASSWORD=change-this-dev-password
