# Backend environment example. Do not commit real secrets.
SPRING_DATA_MONGODB_URI=mongodb://localhost:27017/smart_match
MONGODB_URI=mongodb://localhost:27017/smart_match
FIREBASE_SERVICE_ACCOUNT_JSON=
# Local: path to firebase-service-account.json (copy from Firebase Console)
# Docker Compose: /run/secrets/firebase-service-account.json
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
APP_PAYMENT_WEBHOOK_SECRET=change-me
APP_SEED_ENABLED=false
APP_CV_UPLOAD_DIR=./uploads/cv

# AI matching via OpenRouter (OpenAI-compatible). Leave key blank to use the
# heuristic skill-overlap fallback. Default model is the free auto-router.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
